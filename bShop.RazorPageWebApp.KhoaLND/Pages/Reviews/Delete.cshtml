@page
@model bShop.RazorPageWebApp.KhoaLND.Pages.Reviews.DeleteModel

@{
    ViewData["Title"] = "Delete Review";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Confirm Review Deletion
            </h4>
        </div>

        <div class="card-body">
            <p class="text-danger fw-bold">
                This action cannot be undone.
            </p>

            <dl class="row">

                <dt class="col-sm-3">Rating</dt>
                <dd class="col-sm-9">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Model.Review.Rating)
                        {
                            <i class="bi bi-star-fill text-warning"></i>
                        }
                        else
                        {
                            <i class="bi bi-star text-muted"></i>
                        }
                    }
                </dd>

                <dt class="col-sm-3">Comment</dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrWhiteSpace(Model.Review.Comment)
                                        ? "No comment"
                                        : Model.Review.Comment)
                </dd>

                <dt class="col-sm-3">Buyer</dt>
                <dd class="col-sm-9">
                    @(Model.Review.Buyer?.BuyerId.ToString() ?? "N/A")
                </dd>

                <dt class="col-sm-3">Order Detail</dt>
                <dd class="col-sm-9">
                    @(Model.Review.OrderDetail?.OrderDetailId.ToString() ?? "N/A")
                </dd>

                <dt class="col-sm-3">Product</dt>
                <dd class="col-sm-9">
                    @(Model.Review.Product?.ProductName ?? "N/A")
                </dd>

            </dl>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <a asp-page="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Cancel
            </a>

            <form method="post" class="mb-0">
                <input type="hidden" asp-for="Review.ReviewId" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete Review
                </button>
            </form>
        </div>
    </div>
</div>
