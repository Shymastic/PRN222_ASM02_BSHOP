@page
@using bShop.Entities.KhoaLND.Models

@model bShop.RazorPageWebApp.KhoaLND.Pages.Reviews.IndexModel

@{
    ViewData["Title"] = "Reviews";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
            <h4 class="mb-0">
                <i class="bi bi-star-fill me-2"></i> Product Reviews
            </h4>
            <a asp-page="Create" class="btn btn-light btn-sm">
                <i class="bi bi-plus-circle"></i> Create New
            </a>
        </div>
        <form method="get" asp-page="Index" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label">Rating</label>
                <select name="rating" class="form-select">
                    <option value="">All</option>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <option value="@i" selected="f@(ViewData["Rating"]?.ToString() == i.ToString())">
                            @i star@(i > 1 ? "s" : "")
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Product Name</label>
                <input type="text"
                       name="productName"
                       value="@ViewData["ProductName"]"
                       class="form-control"
                       placeholder="Search product..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Buyer Name</label>
                <input type="text"
                       name="buyerName"
                       value="@ViewData["BuyerName"]"
                       class="form-control"
                       placeholder="Search buyer..." />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>

        <div class="card-body p-0">
            <table  class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th>Created At</th>
                        <th>Buyer</th>
                        <th>Order Detail</th>
                        <th>Product</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="ReviewTbodyId">
                    @if (!Model.Review.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No reviews found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Review)
                        {
                            <tr id="review-@item.ReviewId">
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div>
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= item.Rating)
                                                {
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-muted"></i>
                                                }
                                            }
                                    </div>
                                    <span class="fw-semibold">
                                        @item.Rating / 5
                                    </span>
                                </div>
                            </td>

                            <td style="max-width: 250px;">
                                <span title="@item.Comment">
                                    @(string.IsNullOrEmpty(item.Comment)
                                                                    ? "—"
                                                                    : item.Comment.Length > 80
                                                                    ? item.Comment.Substring(0, 80) + "..."
                                                                    : item.Comment)
                                    </span>
                                </td>

                                <td>
                                    @(item.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
                                </td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @item.BuyerId
                                    </span>
                                </td>

                                <td>
                                    @(item.OrderDetail != null
                                                                ? item.OrderDetail.OrderDetailId.ToString()
                                                                : "—")
                                </td>

                                <td>
                                    @(item.Product != null
                                                                ? item.Product.ProductName
                                                                : "—")
                                </td>

                                <td class="text-end">
                                    <a asp-page="Edit" asp-route-id="@item.ReviewId"
                                       class="btn btn-sm btn-outline-warning me-1">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a asp-page="Details" asp-route-id="@item.ReviewId"
                                       class="btn btn-sm btn-outline-info me-1">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-page="Delete" asp-route-id="@item.ReviewId"
                                       class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>

                                
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/ReviewHub")
        .build();

    connection.start()
        .then(() => console.log("Connected to SignalR hub"))
        .catch(err => console.error(err.toString()));

    function getRatingStars(rating) {
        let stars = "";
        for (let i = 1; i <= 5; i++) {
            stars += i <= rating
                ? "<i class='bi bi-star-fill text-warning me-1'></i>"
                : "<i class='bi bi-star text-muted me-1'></i>";
        }

        return `
            <div class="d-flex align-items-center">
                <div>${stars}</div>
                <span class="fw-semibold ms-1">${rating} / 5</span>
            </div>
        `;
    }

    connection.on("ReceiveDelete", function (reviewId) {
        $("#review-" + reviewId).fadeOut(300, function () {
            $(this).remove();
        });
    });

    connection.on("ReceiveUpdate", function (review) {

        const row = $("#review-" + review.reviewId);
        if (row.length === 0) return;

        const comment = review.comment || "—";
        const shortComment = comment.length > 80
            ? comment.substring(0, 80) + "..."
            : comment;

        const formattedDate = review.createdAt
            ? new Date(review.createdAt).toLocaleString("en-GB", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
                hour: "2-digit",
                minute: "2-digit",
                hour12: false
              })
            : "N/A";

        row.find("td:eq(0)").html(getRatingStars(review.rating));
        row.find("td:eq(1)").html(`<span title="${comment}">${shortComment}</span>`);
        row.find("td:eq(2)").text(formattedDate);
    });
        connection.on("ReceiveCreate", function (review) {

        const comment = review.comment || "—";
        const shortComment = comment.length > 80
            ? comment.substring(0, 80) + "..."
            : comment;

        const formattedDate = review.createdAt
            ? new Date(review.createdAt).toLocaleString("en-GB", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
                hour: "2-digit",
                minute: "2-digit",
                hour12: false
              })
            : "N/A";

        const newRow = `
            <tr id="review-${review.reviewId}">
                <td>${getRatingStars(review.rating)}</td>
                <td><span title="${comment}">${shortComment}</span></td>
                <td>${formattedDate}</td>
                <td><span class="badge bg-secondary">${review.buyerId}</span></td>
                <td>${review.orderDetail ? review.orderDetail.orderDetailId : "—"}</td>
                <td>${review.product ? review.product.productName : "—"}</td>
                <td class="text-end">
                    <a href="/Reviews/Edit?id=${review.reviewId}" class="btn btn-sm btn-outline-warning me-1">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                    <a href="/Reviews/Details?id=${review.reviewId}" class="btn btn-sm btn-outline-info me-1">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a href="/Reviews/Delete?id=${review.reviewId}" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        `;

        // Remove "No reviews found" row if exists
        $("#ReviewTbodyId tr td[colspan='7']").parent().remove();

        // Add new row to top
        $("#ReviewTbodyId").prepend(newRow);
    });
</script>